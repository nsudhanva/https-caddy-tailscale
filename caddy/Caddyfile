(network_paths) {
  handle_path /web1/* {
    reverse_proxy web1:80
  }
  handle_path /web2/* {
    reverse_proxy web2:80
  }
  handle_path /web3/* {
    reverse_proxy web3:80
  }
}

# Replace with this machine's Tailscale domain.
your-machine-name.your-tailnet.ts.net {
  import network_paths
}

